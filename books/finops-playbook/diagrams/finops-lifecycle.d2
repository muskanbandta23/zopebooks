# FinOps Lifecycle: Inform → Optimize → Operate
# Brand: Zopdev (#0052FF primary, #00C48C success, #FFB020 warning)

direction: right

vars: {
  d2-config: {
    layout-engine: elk
    pad: 24
  }
}

inform: INFORM {
  shape: rectangle
  style.fill: "#e3f2fd"
  style.stroke: "#0052FF"
  style.stroke-width: 3
  style.border-radius: 8

  desc: |md
    Visibility • Allocation
    Tag coverage ≥ 80%
  |
}

optimize: OPTIMIZE {
  shape: rectangle
  style.fill: "#e8f5e9"
  style.stroke: "#00C48C"
  style.stroke-width: 3
  style.border-radius: 8

  desc: |md
    Right-size • Reserved instances
    30% waste reduction target
  |
}

operate: OPERATE {
  shape: rectangle
  style.fill: "#fff3e0"
  style.stroke: "#FFB020"
  style.stroke-width: 3
  style.border-radius: 8

  desc: |md
    Governance • Automation
    Policy-as-code for all
  |
}

inform -> optimize: Data-driven actions {
  style.stroke: "#0052FF"
  style.stroke-width: 2
}

optimize -> operate: Sustained savings {
  style.stroke: "#00C48C"
  style.stroke-width: 2
}

operate -> inform: Feedback loop {
  style.stroke: "#FFB020"
  style.stroke-width: 2
  style.stroke-dash: 5
}
